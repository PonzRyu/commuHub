// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// アプリ表示名の表示名（単一行想定: id = 1）。表示時は常に末尾に " CommuHub" を付与する。
model SiteConfig {
  id          Int    @id @default(1)
  displayName String @default("PonzRyu")
}

/// トップバーに表示する外部サイトリンク（最大 5 件）。sortOrder が小さいほど左。
model ExternalNavLink {
  id        String   @id @default(cuid())
  /// メニュー表示名（サイト名）
  label     String
  /// https:// などの絶対 URL
  url       String   @db.Text
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

/// 部署（FR-SEC-*）。名称は一意。
model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  members   Member[]
}

/// メンバー（FR-MEM-*）。所属部署に紐づく。カレンダーは ICS リンクを DB に保持する。
model Member {
  id           String     @id @default(cuid())
  name         String
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  /// 表示順（1 が最優先）。未設定の場合は最後として扱う。
  displayOrder Int?
  /// ICS（iCalendar）リンク（例: https://.../calendar.ics）
  icsUrl       String?    @db.Text
  /// ICS リンクを登録・差し替えした日時（削除時は null）
  icsRegisteredAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([departmentId])
}

/// 週次の周知文（東京・月曜始まりの週ごとに 1 件）
model WeeklyNotice {
  id            String   @id @default(cuid())
  /// その週の月曜日（東京暦 YYYY-MM-DD）
  weekMondayYmd String   @unique
  content       String   @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// 週次の予定表（東京・月曜始まりの週ごとに 1 件）
/// - 「曜日ごとの表（行の追加/削除/編集）」を JSON として保存する
model WeeklyAgendaSchedule {
  id            String   @id @default(cuid())
  /// その週の月曜日（東京暦 YYYY-MM-DD）
  weekMondayYmd String   @unique
  /// 予定表データ（曜日→行配列）
  data          Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
