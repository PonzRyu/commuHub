<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <rule name="ReverseProxyToNextStandalone" stopProcessing="true">
          <match url="(.*)" />
          <serverVariables>
            <!--
              Next.js Server Actions が Origin と forwarded host の不一致で弾かれるのを防ぐ。
              ※ IIS 側で Allow した Server Variables に追加が必要:
                 - HTTP_X_FORWARDED_HOST
                 - HTTP_X_FORWARDED_PROTO
            -->
            <set name="HTTP_X_FORWARDED_HOST" value="25.20.10.200:5443" />
            <set name="HTTP_X_FORWARDED_PROTO" value="https" />
          </serverVariables>
          <!-- Next（node server.js）が待ち受けているローカルポートへ転送 -->
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
  </system.webServer>
</configuration>
