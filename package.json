{
  "name": "commuhub",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "engines": {
    "node": "20.19.0",
    "npm": "10.8.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "machine:start": "podman machine start",
    "db:up": "podman compose up -d",
    "db:down": "podman compose down",
    "db:ps": "podman compose ps",
    "db:logs": "podman compose logs -f db",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "electron:icon": "node scripts/rasterize-electron-icon.mjs",
    "electron:dev": "node scripts/rasterize-electron-icon.mjs && concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron .\"",
    "electron:prepare": "node scripts/electron-prepare.mjs",
    "electron:pack": "npm run build && npm run electron:prepare && electron-builder --win"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "node-ical": "^0.26.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.2",
    "dotenv": "^17.4.1",
    "electron": "^35.1.5",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.commuhub.app",
    "productName": "CommuHub",
    "directories": {
      "output": "dist-electron"
    },
    "icon": "electron/assets/commuHubIcon.svg",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "next-standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron-resources/bundled-node",
        "to": "bundled-node",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "electron/assets/commuHubIcon.ico",
      "target": [
        "nsis"
      ]
    }
  }
}
