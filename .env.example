# docker compose で起動する PostgreSQL 向けの例。`.env` にコピーして利用する。
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres?schema=commuhub"

# 部署・メンバー管理画面用（NFR-SEC-01）。本番では十分に長くランダムな値にする。
ADMIN_PASSWORD="change-me"
# セッション Cookie 署名用（推奨: 32 文字以上のランダム文字列）
ADMIN_SESSION_SECRET="replace-with-long-random-secret"

# Electron 配布時（パッケージ版）に表示する接続先 URL（IIS でホストしている URL を指定）
# 例: COMMUHUB_ELECTRON_REMOTE_URL=""
COMMUHUB_ELECTRON_REMOTE_URL=""
